params.executor = "sge"

// define your preferred queues here
params.default_queue = ''  // Default queue
params.gpu_queue = null  // Optional: Only set if GPU queue is needed and different from default queue

// Detect engine: prefer apptainer if available, else singularity
def hasApptainer = ['bash','-c','command -v apptainer'].execute().waitFor() == 0
def hasSingularity = ['bash','-c','command -v singularity'].execute().waitFor() == 0

if( hasSingularity ) {
    singularity {
        enabled = true
        pullTimeout = '3h'
        autoMounts = true
        cacheDir = "${System.getenv('HOME')}/Scratch/.apptainer/pull"

        runOptions = "-B ${System.getenv('HOME')},${System.getenv('PWD')} --no-mount /scratch --writable-tmpfs"
        singularity.enabled = true
        singularity.autoMounts = true
        platform = 'linux/amd64'
    } 
}
else if( hasApptainer ) {
    apptainer {
        enabled = true
        pullTimeout = '3h'
        autoMounts = true
        cacheDir = "${System.getenv('HOME')}/Scratch/.apptainer/pull"
        runOptions = "-B ${System.getenv('HOME')},${System.getenv('PWD')} --no-mount /scratch --writable-tmpfs"
        apptainer.enabled = true
        apptainer.autoMounts = true
        platform = 'linux/amd64'
    }
}
else {
    throw new RuntimeException("Neither apptainer nor singularity found in PATH")
}

process {
    executor = 'sge'
    queue = params.default_queue
    debug = true
    // stageInMode = 'copy'
    scratch = false

    // to ensure tmp dir exists and is used
    beforeScript = 'mkdir -p $HOME/Scratch/.apptainer/tmp && export APPTAINER_TMPDIR=$HOME/Scratch/.apptainer/tmp && export SINGULARITY_TMPDIR=$HOME/Scratch/.apptainer/tmp'
    
    // SGE: multi-slot parallel environment for multi-core jobs
    // Replace 'smp' with the name of your site's PE (e.g. 'orte', 'mpi', 'openmp')
    penv = 'smp'

    withName: job_dispatch {
    cpus = 4
    memory = '32 GB'      // 8G/slot - same as before, just let NF handle it
    time = '1h'
    clusterOptions = '-l tmpfs=10G'
    }
    withName: preprocessing {
        cpus = 16
        memory = '64 GB'      // 4G/slot
        time = { max_duration_minutes.toFloat()*4 > 60 ? max_duration_minutes.toFloat()*4 + 'm' : '60m' }
        clusterOptions = '-l tmpfs=50G'
    }
    withName: spikesort_kilosort4 {
        cpus = 16
        memory = '64 GB'
        containerOptions = '--nv'
        clusterOptions = '-l gpu=1,tmpfs=50G'
        queue = params.gpu_queue ?: params.default_queue
        time = { max_duration_minutes.toFloat()*4 > 60 ? max_duration_minutes.toFloat()*4 + 'm' : '60m' }
    }
    withName: spikesort_kilosort25 {
        cpus = 16
        memory = '64 GB'
        containerOptions = '--nv'
        clusterOptions = '-l gpu=1,tmpfs=50G'
        queue = params.gpu_queue ?: params.default_queue
        time = { max_duration_minutes.toFloat()*4 > 60 ? max_duration_minutes.toFloat()*4 + 'm' : '60m' }
    }
    withName: spikesort_spykingcircus2 {
        cpus = 16
        memory = '64 GB'
        time = { max_duration_minutes.toFloat()*4 > 60 ? max_duration_minutes.toFloat()*4 + 'm' : '60m' }
        clusterOptions = '-l tmpfs=50G'
    }
    withName: postprocessing {
        cpus = 16
        memory = '64 GB'
        time = { max_duration_minutes.toFloat()*4 > 60 ? max_duration_minutes.toFloat()*4 + 'm' : '60m' }
        clusterOptions = '-l tmpfs=50G'
    }
    withName: curation {
        cpus = 4
        memory = '32 GB'
        time = { max_duration_minutes.toFloat()/6 > 10 ? max_duration_minutes.toFloat()/6 + 'm' : '10m' }
        clusterOptions = '-l tmpfs=10G'
    }
    withName: visualization {
        cpus = 4
        memory = '32 GB'
        time = { max_duration_minutes.toFloat()*2 > 30 ? max_duration_minutes.toFloat()*2 + 'm' : '30m' }
        clusterOptions = '-l tmpfs=10G'
    }
    withName: results_collector {
        cpus = 4
        memory = '32 GB'
        time = { max_duration_minutes.toFloat() > 10 ? max_duration_minutes.toFloat() + 'm' : '10m' }
        clusterOptions = '-l tmpfs=10G'
    }
    withName: quality_control {
        cpus = 16
        memory = '64 GB'
        time = { max_duration_minutes.toFloat()*2 > 60 ? max_duration_minutes.toFloat()*2 + 'm' : '60m' }
        clusterOptions = '-l tmpfs=50G'
    }
    withName: quality_control_collector {
        cpus = 4
        memory = '32 GB'
        time = { max_duration_minutes.toFloat()/6 > 10 ? max_duration_minutes.toFloat()/6 + 'm' : '10m' }
        clusterOptions = '-l tmpfs=10G'
    }
    withName: nwb_subject {
        cpus = 4
        memory = '32 GB'
        time = { max_duration_minutes.toFloat()/6 > 10 ? max_duration_minutes.toFloat()/6 + 'm' : '10m' }
        clusterOptions = '-l tmpfs=10G'
    }
    withName: nwb_ecephys {
        cpus = 16
        memory = '128 GB'
        time = { max_duration_minutes.toFloat()*4 > 60 ? max_duration_minutes.toFloat()*4 + 'm' : '60m' }
        clusterOptions = '-l tmpfs=50G'
    }
    withName: nwb_units {
        cpus = 4
        memory = '32 GB'
        time = { max_duration_minutes.toFloat()*2 > 30 ? max_duration_minutes.toFloat()*2 + 'm' : '30m' }
        clusterOptions = '-l tmpfs=10G'
    }
}


dag {
    enabled = true
    file = RESULTS_PATH + '/nextflow/dag.html'
    overwrite = true
}

report {
    enabled = true
    file = RESULTS_PATH + '/nextflow/report.html'
    overwrite = true
}

timeline {
    enabled = true
    file = RESULTS_PATH + '/nextflow/timeline.html'
    overwrite = true
}

trace {
    enabled = true
    file = RESULTS_PATH + '/nextflow/trace.txt'
    overwrite = true
}